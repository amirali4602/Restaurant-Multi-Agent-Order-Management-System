QGroupBox {
    background: #27272A;
    color: #F4F4F5;   /* Title color */
    border: 1px solid #3F3F46;
    border-radius: 12px;
}

QGroupBox::title {

    color: #2D3748;

    subcontrol-origin: margin;
    subcontrol-position: top left;

    left: 12px;
    padding: 0 6px;

    font-size: 16px;
    font-weight: bold;
}