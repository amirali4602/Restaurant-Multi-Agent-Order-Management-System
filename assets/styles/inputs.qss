QLineEdit {

    background: white;

    border: 1px solid #D6D6D6;

    border-radius: 10px;

    padding: 8px;

    color: #333333;
}

QLineEdit:focus {

    border: 2px solid #F57C00;
}

QTextEdit {

    background: white;

    border: 1px solid #D6D6D6;

    border-radius: 10px;

    color: #333333;

    padding: 10px;
}